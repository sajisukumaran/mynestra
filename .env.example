# Copy to .env for local/Docker dev:  cp .env.example .env
# .env is gitignored; .env.example is the committed template.

# --- Django ---
SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
ENVIRONMENT=dev
ALLOW_HARD_DELETE=1
# DJANGO_SETTINGS_MODULE is intentionally NOT set here: manage.py defaults to config.settings.dev,
# and pytest uses config.settings.test (see pyproject.toml). Set it explicitly only for prod.

# --- Web / nginx ---
WEB_PORT=8080

# Mailpit web UI host port. Default 8025; override if a shared/other Mailpit already holds it.
MAILPIT_PORT=8025

# --- Database (PostgreSQL 17) ---
POSTGRES_DB=mynestra
POSTGRES_USER=mynestra
POSTGRES_PASSWORD=mynestra
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Email (Mailpit) ---
EMAIL_HOST=mailpit
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=MyNestra <no-reply@mynestra.local>
